{"id":"40107","title":"逍遥侯","writer":"醉卧红尘","dateline":"1444032717","updatetime":"1444032717","isover":"1","filesize":"1362192","linecount":"16308","wordcount":"427809","imgpath":"https://ae01.alicdn.com/kf/UTB86SkPO0oSdeJk43Owq6ya4XXav.jpg","hash":"xiaoyaohou","urlhash":"","sign":"","desc":"连城二星VIP完结\n总推荐：12208 总人气：3842165 \n文案：\n高傲不可一世兼美艳无双的逍遥侯被男人压了。\n魔宫之主殇景年：我是魔教教主我怕谁！逍遥侯，本尊照压不误。\n肃王李睿深情款款：执子之手，将子压倒。随即化身为狼。\n弟弟：哥哥，权势有风险 ，弄权需谨慎。\n前有狼，后有虎，还有一个弟弟时刻惦记着要篡权。\n逍遥侯咬牙切齿，这日子还要不要人活了？\n逍遥侯的关键字：蛇蝎美人 强强 1V1，逍遥侯，醉卧红尘 \n不要删，坛子里的没有完结！","hot":"4104","num":"472000","cid":"147","suggcate":"耽美同人","suggcids":"147,115","notbook":"0","fetchv":"0","lasthot":"1477855124","clicknum":"112","isvip":"1","ish":"0","age":"古代","channel":"女","isqiniu":"1","list":"0,1y9,42c,62r,7xd,9yf,bn7,dl3,flc,hpo,jpj,ljw,npp,qcg,sno,uhf,wdr,y3a,1010,124h,145s,165f,17u4,19qp,1bys,1e6g,1g64,1if1,1khs,1mfl,1ol9,1qx0,1tf2,1vg3,1xng,1zrm,21uh,23ys,25ut,27sc,2a3y,2c78,2eir,2gqg,2it0,2kp1,2mk4,2ouk,2qy2,2t90,2v33,2wz8,2z5n,31bh,338r,35fr,37hw,39ou,3bvf,3dtg,3fxn,3igc,3kr5,3mvj,3p24,3r6i,3tv7,3vx4,3xt5,3zrf,4275,4442,463h,483n,4a6l,4cab,4ege,4gmx,4iqo,4kx2,4n2w,4p6x,4r4l,4tlo,4vya,4y54,509x,524p,549u,563i,57w1,5a5j,5c6p,5e4c,5g0y,5ial,5kfu,5n02,5p3t,5r5w,5t36,5uyx,5wtq,5ymg,60gc,62n5,64rf,66z8,697c,6bee,6d8w,6f2y,6h1h,6j99,6l9g,6ngg,6pk0,6rlf,6tw7,6vxm,6y7g,70g4,72uo,75bs,77sj,79zg,7c82,7e6u,7gdu,7ire,7kmm,7mpf,7p65,7r9r,7tdy,7vcd,7xb7,7zq0,822p,8409,85xt,8889,8amk,8d5w,8fmz,8i8d,8kum,8n7u,8pl2,8s49,8ujm,8x0c,8zba,91l1,93uv,969f,98u5,9bdh,9ec1,9gl5,9ivb,9l7v,9n1v,9ptr,9sel,9uxh,9x50,9zjv,a1nu,a3yc,a62p,a89n,aavg,adnb,ag98,aj2k,alwe,aojx,aqt9,at3g,avs8,ayj4,b0og,b37x,b5kw,b7tw,ba6g,bcd6,bezz,bh7f,bjrm,bm41,boeg,bqhg,bsvn,bv92,bxox,c08x,c2v1,c5k0,c818,cakt,cczl,cfnf,cid3,ckux,cna8,cpm4,crqb,cub3,cwpx,czak,d211,d4if,d6ux,d96m,dbdx,ddqn,dfuh,di3a,dkir,dmrs,dpal,drfk,dtq0,dvsn,dya2,e0g5,e2i7,e4ff,e6jo,e8y8,eb4a","pages":"233","errors":"0","stars":"375","starcounts":"2","isbroken":"0","iswx":"1","leader":"殇景年","ins3":"1"}